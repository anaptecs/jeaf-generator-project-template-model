            <language>StructuredExpression</language>
            <body>&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot; standalone=&quot;yes&quot;?>&#xA;&lt;unionExpressionSpecification xmlns=&quot;http://www.nomagic.com/schemas/MagicDraw/StructuredExpression/2013&quot;>&#xA;    &lt;taggedValues>&#xA;        &lt;entry key=&quot;name&quot;>&#xA;            &lt;value>Body&lt;/value>&#xA;        &lt;/entry>&#xA;        &lt;entry key=&quot;ROOT_UNION&quot;>&#xA;            &lt;value>true&lt;/value>&#xA;        &lt;/entry>&#xA;    &lt;/taggedValues>&#xA;    &lt;value xsi:type=&quot;callExpressionSpecification&quot; includeCustomTypes=&quot;true&quot; includeSubtypes=&quot;false&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot;>&#xA;        &lt;taggedValues>&#xA;            &lt;entry key=&quot;name&quot;>&#xA;                &lt;value>Script1&lt;/value>&#xA;            &lt;/entry>&#xA;        &lt;/taggedValues>&#xA;        &lt;argument xsi:type=&quot;callExpressionSpecification&quot; includeCustomTypes=&quot;true&quot; includeSubtypes=&quot;false&quot;>&#xA;            &lt;taggedValues>&#xA;                &lt;entry key=&quot;name&quot;>&#xA;                    &lt;value>Find1&lt;/value>&#xA;                &lt;/entry>&#xA;            &lt;/taggedValues>&#xA;            &lt;argument xsi:type=&quot;stringExpressionSpecification&quot;>&#xA;                &lt;value>*&lt;/value>&#xA;            &lt;/argument>&#xA;            &lt;argument xsi:type=&quot;callExpressionSpecification&quot; includeCustomTypes=&quot;true&quot; includeSubtypes=&quot;false&quot;>&#xA;                &lt;taggedValues>&#xA;                    &lt;entry key=&quot;name&quot;>&#xA;                        &lt;value>Script1&lt;/value>&#xA;                    &lt;/entry>&#xA;                &lt;/taggedValues>&#xA;                &lt;argument xsi:type=&quot;lookupExpressionSpecification&quot; symbol=&quot;THIS&quot;/>&#xA;                &lt;expression xsi:type=&quot;makeInlineExpressionSpecification&quot; language=&quot;Groovy&quot;>&#xA;                    &lt;parameter name=&quot;arg1&quot; type=&quot;java.lang.Object&quot; ordered=&quot;false&quot; unique=&quot;false&quot; multiple=&quot;false&quot;/>&#xA;                    &lt;body>return  valueContext.getValue(&quot;scope&quot;)&lt;/body>&#xA;                &lt;/expression>&#xA;            &lt;/argument>&#xA;            &lt;argument xsi:type=&quot;callExpressionSpecification&quot; includeCustomTypes=&quot;true&quot; includeSubtypes=&quot;false&quot;>&#xA;                &lt;taggedValues>&#xA;                    &lt;entry key=&quot;name&quot;>&#xA;                        &lt;value>Script1&lt;/value>&#xA;                    &lt;/entry>&#xA;                &lt;/taggedValues>&#xA;                &lt;argument xsi:type=&quot;lookupExpressionSpecification&quot; symbol=&quot;THIS&quot;/>&#xA;                &lt;expression xsi:type=&quot;makeInlineExpressionSpecification&quot; language=&quot;Groovy&quot;>&#xA;                    &lt;parameter name=&quot;arg1&quot; type=&quot;java.lang.Object&quot; ordered=&quot;false&quot; unique=&quot;false&quot; multiple=&quot;false&quot;/>&#xA;                    &lt;body>return valueContext.getValue(&quot;type&quot;)&lt;/body>&#xA;                &lt;/expression>&#xA;            &lt;/argument>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;stringExpressionSpecification&quot;>&#xA;                &lt;value>&lt;/value>&#xA;            &lt;/argument>&#xA;            &lt;argument xsi:type=&quot;stringExpressionSpecification&quot;>&#xA;                &lt;value>&lt;/value>&#xA;            &lt;/argument>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;true&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;expression xsi:type=&quot;interpretElementExpressionSpecification&quot;>&#xA;                &lt;element xsi:type=&quot;elementExpressionSpecification&quot; element=&quot;5f060e30-6793-405f-b19d-258aa1b0b0e7&quot;/>&#xA;            &lt;/expression>&#xA;        &lt;/argument>&#xA;        &lt;expression xsi:type=&quot;makeInlineExpressionSpecification&quot; language=&quot;Groovy&quot;>&#xA;            &lt;parameter name=&quot;arg1&quot; type=&quot;java.lang.Object&quot; ordered=&quot;false&quot; unique=&quot;false&quot; multiple=&quot;false&quot;/>&#xA;            &lt;body>import com.nomagic.uml2.ext.jmi.helpers.StereotypesHelper&#xA;import com.nomagic.uml2.ext.magicdraw.classes.mdkernel.InstanceSpecification&#xA;&#xA;Set set = (HashSet)arg1;&#xA;return set.size()&lt;/body>&#xA;        &lt;/expression>&#xA;    &lt;/value>&#xA;&lt;/unionExpressionSpecification>&#xA;</body>
